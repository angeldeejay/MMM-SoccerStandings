{
	"name": "MMM-SoccerStandings",
	"version": "1.0.0",
	"description": "A MagicMirror² module to display football league standings from multiple European competitions",
	"main": "MMM-SoccerStandings.js",
	"keywords": [
		"MagicMirror",
		"module",
		"SPFL",
		"Scottish Premier League",
		"football",
		"soccer",
		"league table",
		"standings",
		"sports",
		"Celtic"
	],
	"author": {
		"name": "gitgitaway",
		"email": " "
	},
	"license": "MIT",
	"homepage": "https://github.com/gitgitaway/MMM-SoccerStandings",
	"repository": {
		"type": "git",
		"url": "https://github.com/gitgitaway/MMM-SoccerStandings.git"
	},
	"bugs": {
		"url": "https://github.com/gitgitaway/MMM-SoccerStandings/issues"
	},
	"engines": {
		"node": ">=14.0.0"
	},
	"dependencies": {
		"node-fetch": "^3.3.2"
	},
	"devDependencies": {
		"eslint": "^10.2.1",
		"mocha": "^11.7.5",
		"prettier": "^3.8.3",
		"sass": "^1.99.0"
	},
	"scripts": {
		"test": "npm run test:security",
		"test:security": "mocha tests/security.test.js --timeout 10000",
		"lint": "eslint *.js",
		"format": "prettier --write *.js *.json *.md",
		"audit": "npm audit --audit-level=moderate",
		"audit:fix": "npm audit fix",
		"scss:build": "sass scss/MMM-SoccerStandings.scss MMM-SoccerStandings.css",
		"scss:watch": "sass --watch scss/MMM-SoccerStandings.scss:MMM-SoccerStandings.css",
		"postinstall": "sass scss/MMM-SoccerStandings.scss MMM-SoccerStandings.css"
	},
	"magicmirror": {
		"moduleName": "MMM-SoccerStandings",
		"moduleVersion": "1.0.0",
		"requiredVersion": "2.1.0"
	}
}