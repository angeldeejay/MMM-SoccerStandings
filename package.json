{
	"name": "MMM-SoccerStandings",
	"version": "3.0.0",
	"description": "A MagicMirror² module for API-first football standings and tournament views",
	"main": "MMM-SoccerStandings.js",
	"keywords": [
		"MagicMirror",
		"module",
		"SPFL",
		"Scottish Premier League",
		"football",
		"soccer",
		"league table",
		"standings",
		"sports",
		"Celtic"
	],
	"author": {
		"name": "Andrés Vanegas Jiménez",
		"url": "https://github.com/angeldeejay"
	},
	"license": "MIT",
	"homepage": "https://github.com/angeldeejay/MMM-SoccerStandings",
	"repository": {
		"type": "git",
		"url": "https://github.com/angeldeejay/MMM-SoccerStandings.git"
	},
	"bugs": {
		"url": "https://github.com/angeldeejay/MMM-SoccerStandings/issues"
	},
	"engines": {
		"node": ">=14.0.0"
	},
	"dependencies": {
		"node-fetch": "^3.3.2"
	},
	"devDependencies": {
		"@fortawesome/fontawesome-free": "^7.2.0",
		"chokidar": "^5.0.0",
		"eslint": "^10.2.1",
		"express": "^5.2.1",
		"mocha": "^11.7.5",
		"moment": "^2.30.1",
		"moment-timezone": "^0.6.1",
		"prettier": "^3.8.3",
		"sass": "^1.99.0",
		"socket.io": "^4.8.3"
	},
	"scripts": {
		"test": "npm run test:security",
		"test:security": "mocha tests/security.test.js --timeout 10000",
		"lint": "eslint *.js constants/*.js providers/*.js backend/*.js backend/providers/*.js",
		"format": "prettier --write *.js constants/*.js providers/*.js backend/*.js backend/providers/*.js tests/*.js *.json *.md",
		"audit": "npm audit --audit-level=moderate",
		"audit:fix": "npm audit fix",
		"postinstall": "sass --style=compressed scss/entrypoint.scss MMM-SoccerStandings.css",
		"scss:build": "sass --style=compressed scss/entrypoint.scss MMM-SoccerStandings.css",
		"scss:watch": "sass --watch scss/entrypoint.scss:MMM-SoccerStandings.css",
		"harness:start": "node tools/magicmirror-harness/server/index.js",
		"harness:start:live": "npm run harness:start",
		"harness:watch": "node tools/magicmirror-harness/server/index.js --watch",
		"harness:watch:live": "npm run harness:watch",
		"mock-api:start": "node tools/espn-service-mock/server/index.js"
	},
	"magicmirror": {
		"moduleName": "MMM-SoccerStandings",
		"moduleVersion": "1.0.0",
		"requiredVersion": "2.1.0"
	}
}
